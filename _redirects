# Cloudflare Pages – Redirects
# Format: source  destination  status_code
#
# Note on pretty URLs: Cloudflare Pages serves `register.html` at `/register`
# automatically and 301s `/register.html` → `/register`. We do NOT add explicit
# `/register → /register.html (200)` rewrites here because they create infinite
# 308 loops with the auto .html-stripping behavior.

# pages.dev → canonical domain
https://przypominamy-com.pages.dev/*  https://przypominamy.com/:splat  301

# Old WordPress paths → canonical (301 permanent)
/uslugi/          /#uslugi         301
/uslugi           /#uslugi         301
/kontakt/         /#kontakt        301
/kontakt          /#kontakt        301
/cennik/          /#cennik         301
/cennik           /#cennik         301

# Old WordPress case study / portfolio pages
/casestudy/*      /                301
/case-study/*     /                301
/portfolio/*      /                301

# Old WordPress content paths
/wp-content/*     /                301
/wp-admin/*       /                301
/wp-login.php     /                301
/feed/*           /                301
/feed             /                301

# Panel redirect
/panel            https://panel.przypominamy.com    302
/login            https://panel.przypominamy.com    302

# API docs (old path → new)
/api-docs         /xmlapi_en_przypominamy2020v17.pdf  301

# Polish-language alias for /register
/rejestracja      /register        301
/rejestracja/     /register        301

# Old blog-index.html alias (legacy, before blog/index.html was added)
/blog-index       /blog            301
/blog-index.html  /blog            301
